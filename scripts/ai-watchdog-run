#!/usr/bin/env bash
# Shell wrapper for ai-watchdog
# Usage: ./scripts/ai-watchdog-run "<command>"
# Example: ./scripts/ai-watchdog-run "python transcribe_images.py"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

exec python -m ai_guardrails.operational_safety.ai_watchdog run -- "$@"
